# Canonical origin for sitemap, canonical URLs, and sharing (production: https://www.turnberryplaceforsale.com)
NEXT_PUBLIC_BASE_URL=https://www.turnberryplaceforsale.com

# Optional: Google Search Console — HTML tag verification (value only, not the full meta tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# -----------------------------------------------------------------------------
# Google Business Profile — Reviews CTA
# -----------------------------------------------------------------------------
# When unset, the "View Google Reviews" / "Write a Review" CTAs fall back to
# a Google Maps Search URL built from the site's canonical NAP (Turnberry
# Place, 2827 Paradise Rd, Las Vegas, NV 89109) which resolves to the
# building's GBP on Google Maps. See lib/reviews.ts.
#
# Best practice: grab the deep links from your GBP dashboard and paste them
# below. Two ways to source them:
#
#   1. Open Google Business Profile → "Customers" → "Reviews" → "Get more
#      reviews" → copy the g.page/r/... short link into NEXT_PUBLIC_GBP_WRITEREVIEW_URL.
#   2. OR use Google's Place ID Finder:
#        https://developers.google.com/maps/documentation/places/web-service/place-id#find-id
#      Copy the ChIJ... place_id into NEXT_PUBLIC_GBP_PLACE_ID and the helper
#      will build both read and write URLs for you.
#
# Explicit URLs take precedence over NEXT_PUBLIC_GBP_PLACE_ID.
# NEXT_PUBLIC_GBP_REVIEWS_URL=https://search.google.com/local/reviews?placeid=ChIJxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_GBP_WRITEREVIEW_URL=https://search.google.com/local/writereview?placeid=ChIJxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_GBP_PLACE_ID=ChIJxxxxxxxxxxxxxxxx
#
# Hide both CTAs entirely without removing code (e.g. during a GBP migration):
# NEXT_PUBLIC_GBP_REVIEWS_DISABLED=true

NEXT_PUBLIC_DRUPAL_BASE_URL=http://localhost:8080
NEXT_IMAGE_DOMAIN=localhost
DRUPAL_CLIENT_ID=52ce1a10-bf5c-4c81-8edf-eea3af95da84
DRUPAL_CLIENT_SECRET=SA9AGbHnx6pOamaAus2f9LG9XudHFjKs
DRUPAL_SITE_ID=example_marketing
DRUPAL_FRONT_PAGE=/home
